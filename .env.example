# ShroomFinder Base44 .env.example
# Copy to .env.local for local dev if supported, but in Base44 set via dashboard Secrets.
# NEVER commit real keys.

# Stripe (required for premium)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_yourkeyhere
# Backend secrets set in Base44 dashboard, accessed via Deno.env.get

# Map (optional for advanced interactive map with Mapbox instead of OSM)
VITE_MAPBOX_ACCESS_TOKEN=pk.yourmapboxkey

# Satellite for map predictions (Sentinel Hub)
# Set as secrets in Base44 for functions: SENTINEL_HUB_CLIENT_ID, SENTINEL_HUB_CLIENT_SECRET

# Plant ID (optional)
# PLANTNET_API_KEY=yourkey

# Base44 (set VITE_BASE44_APP_ID to your app's ID from dashboard/editor URL)
VITE_BASE44_APP_ID=6a4ed4b6e92de775028c4011
# If using api_key header auth (per your Base44 client config), set this:
VITE_BASE44_API_KEY=your_api_key_here
# Optional base url for advanced proxy
# VITE_BASE44_APP_BASE_URL=...